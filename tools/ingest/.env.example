# YouTube Data API v3 key (create at https://console.cloud.google.com/apis/credentials,
# enable "YouTube Data API v3"). Free quota: 10,000 units/day — a full channel
# resync costs a few hundred units.
YT_API_KEY=

# Phase 2 (optional Supabase mirror + storage upload) — not needed for MVP:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
